function printtab(t, type, tag)
local info = debug.getinfo(2, "Sl")
local line = info.currentline

if t == nil then
insert(errortable, line..": Error--table no specified (>t<, type, order)")
error = true
end

if type == nil then
insert(errortable, line..": Error--type not specified (t, >type<, order)")
insert(errortable, line..": Types: array; key;")
error = true
end

if type == "array" then
for i, v in ipairs(t) do
  if tag then
    print(i..". "..v)
    else
    print(v)
    end
end
end

if type == "key" then
for k, v in pairs(t) do
  if tag then
    print(k..": "..v)
    else
    print(v)
    end
end
end

end



