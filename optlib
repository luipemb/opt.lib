function insert(tab, v)
table.insert(tab, v) 
end

function remove(tab, v)
table.remove(tab, v)
end

function concat(tab, plus)
if plus == nil then
table.concat(tab)
else
table.concat(tab, plus)
end
end

function checkintab(t, val)
for i, v in ipairs(t) do 
return v == val
end
end

function printtab(t, type, tag)
if type == "array" then
for i, v in ipairs(t) do
  if tag then
    print(i..". "..v)
    else
    print(v)
    end

if type == "key" then
for k, v in pairs(t) do
  if tag then
    print(k..": "..v)
    else
    print(v)
    end

end
  




