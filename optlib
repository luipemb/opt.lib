function printtab(t, type, tag)
local info = debug.getinfo(2, "Sl")
local line = info.currentline

if t == nil then
insert(errortable, line..": Error--table no specified (>t<, type, order)")
error = true
end

if type == nil then
insert(errortable, line..": Error--type not specified (t, >type<, order)")
insert(errortable, line..": Types: array; key;")
error = true
end

if type == "array" then
for i, v in ipairs(t) do
  if tag then
    print(i..". "..v)
    else
    print(v)
    end
end
end

if type == "key" then
for k, v in pairs(t) do
  if tag then
    print(k..": "..v)
    else
    print(v)
    end
end
end

end



-- Tentamos pegar o shell do ambiente global ou do ambiente atual
local sh = _G.shell or shell

if sh then
    local originalRun = sh.run

    sh.run = function(...)
        -- 1. Roda o programa
        local result = { originalRun(...) }
        
        -- 2. No final (o "end"), verifica a tabela
        -- Usamos next() porque você disse que é uma tabela de chaves
        if _G.errortable and next(_G.errortable) then
            tcolor("red")
            print("\n[!] Erros acumulados na execucao:")
            
            -- Usa sua printtab para mostrar os erros
            printtab(_G.errortable, "key", true)
            
            tcolor()
            _G.errortable = {} -- Limpa para a próxima rodada
        end
        
        return unpack(result)
    end
else
    -- Se mesmo assim for nil, avisamos no console
    print("Aviso: Nao foi possivel 'hackear' o shell.run")
end


