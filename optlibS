end
--========================================================================================================
function ping(actON, actOFF)
local f1 = load(actON)
local f2 = load(actOFF)
while true do

sender, data = rednet.receive(1)
if sender then
 if actON == nil then
 return true
 else
 reset()
 f1()
 end
lastping = os.clock()
end

if os.clock() - lastping > 0.5 then
 if actOFF ~= nil then
 reset()
 f2()
 end
end
sleep(0.5)
end
end
--========================================================================================================
function pressed(k)
 while true do
  local event, key, is_held = os.pullEvent("key")
  local keyname = keys.getName(key)

  if keyname == k then 
   return true
   end
  end
end
--========================================================================================================
function constant(time, cmd)
    local c = load(cmd)
    local running = true

    while running do
        c()
       
        local t = os.startTimer(time)
        while true do
            local event, p1 = os.pullEvent()
            if event == "timer" and p1 == t then 
                break 
            elseif event == "key" and keys.getName(p1) == "leftCtrl" then
                running = false 
                break
            end
        end
    end
end




