function tcolor(c)
if c == nil then
    term.setTextColor(colors.white)
else
    local color = colors[c] or c
    term.setTextColor(color)
end
end

function bcolor(c)
if c == nil then
    term.setBackgroundColor(colors.white)
else
    local color = colors[c] or c
    term.setBackgroundColor(color)
end
end


function clear()
  term.clear()
end

function cursorpos(x, y)
  if x == nil or y == nil then
  term.setCursorPos(1, 1)
  else
  term.setCursorPos(x, y)
end
end


function reset()
    term.clear()
    term.setCursorPos(1,1)
end


function table(t, v, act)
if act == "insert" then
return table.insert(t, v)

elseif act == "remove" then
return table.remove(t, v)
end
end

